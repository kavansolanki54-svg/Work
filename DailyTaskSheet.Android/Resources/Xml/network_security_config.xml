<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration
    - Production: HTTPS only (no cleartext)
    - Debug: Allows cleartext for localhost/10.0.2.2 (emulator) only
-->
<network-security-config>

    <!-- Default: block cleartext (HTTP) traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext for local development only in debug builds -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>

    <!-- Allow cleartext for localhost/emulator during development -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

</network-security-config>
