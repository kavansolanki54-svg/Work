<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:Callyzer.App.Converters">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Converters -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <converters:DurationDisplayConverter x:Key="DurationConverter" />
    <converters:CallTypeToColorConverter x:Key="CallTypeColorConverter" />
    <converters:CallTypeToIconConverter x:Key="CallTypeIconConverter" />
    <converters:BoolToColorConverter x:Key="BoolToColorConverter" />

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Page Style -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundColor}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource SurfaceColor}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextPrimaryColor}" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource SurfaceColor}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextTertiaryColor}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Label Styles -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Style x:Key="Headline" TargetType="Label">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
    </Style>

    <Style x:Key="Title" TargetType="Label">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
    </Style>

    <Style x:Key="Subtitle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondaryColor}" />
    </Style>

    <Style x:Key="Body" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
    </Style>

    <Style x:Key="Caption" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextTertiaryColor}" />
    </Style>

    <Style x:Key="StatValue" TargetType="Label">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryColor}" />
    </Style>

    <Style x:Key="StatLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextTertiaryColor}" />
        <Setter Property="CharacterSpacing" Value="1" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Button Styles -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="TextColor" Value="{StaticResource TextOnPrimaryColor}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="BorderColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Entry / SearchBar Styles -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextTertiaryColor}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceVariantColor}" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextTertiaryColor}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceVariantColor}" />
        <Setter Property="CancelButtonColor" Value="{StaticResource PrimaryColor}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Card Frame Style -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Style x:Key="Card" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Activity Indicator -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource PrimaryColor}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Collection View -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Style TargetType="CollectionView">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

</ResourceDictionary>
