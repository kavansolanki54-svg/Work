<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Brand Colors — Dark Theme Palette -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Color x:Key="PrimaryColor">#6C63FF</Color>
    <Color x:Key="PrimaryDarkColor">#5A52E0</Color>
    <Color x:Key="PrimaryLightColor">#8B84FF</Color>
    <Color x:Key="SecondaryColor">#00D9FF</Color>
    <Color x:Key="AccentColor">#FF6B6B</Color>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Surface & Background Colors -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Color x:Key="BackgroundColor">#0F0F1A</Color>
    <Color x:Key="SurfaceColor">#1A1A2E</Color>
    <Color x:Key="SurfaceVariantColor">#242440</Color>
    <Color x:Key="CardColor">#1E1E36</Color>
    <Color x:Key="CardHoverColor">#2A2A4A</Color>
    <Color x:Key="BorderColor">#2E2E50</Color>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Text Colors -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#A0A0C0</Color>
    <Color x:Key="TextTertiaryColor">#6E6E8F</Color>
    <Color x:Key="TextOnPrimaryColor">#FFFFFF</Color>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Call Type Colors -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Color x:Key="IncomingColor">#4CAF50</Color>
    <Color x:Key="OutgoingColor">#2196F3</Color>
    <Color x:Key="MissedColor">#F44336</Color>
    <Color x:Key="RejectedColor">#FF9800</Color>
    <Color x:Key="BlockedColor">#9E9E9E</Color>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Status Colors -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>
    <Color x:Key="ErrorColor">#F44336</Color>
    <Color x:Key="InfoColor">#2196F3</Color>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Trend Colors -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <Color x:Key="TrendUpColor">#4CAF50</Color>
    <Color x:Key="TrendDownColor">#F44336</Color>
    <Color x:Key="TrendNeutralColor">#9E9E9E</Color>

</ResourceDictionary>