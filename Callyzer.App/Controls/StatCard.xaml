<?xml version="1.0" encoding="utf-8" ?>
<ContentView 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Callyzer.App.Controls.StatCard"
    x:Name="this">

    <Frame Style="{StaticResource Card}" Padding="12">
        <VerticalStackLayout Spacing="4" VerticalOptions="Center">
            
            <Label x:Name="ValueLabel"
                   Text="{Binding Value, Source={x:Reference this}}"
                   Style="{StaticResource StatValue}"
                   TextColor="{Binding ValueColor, Source={x:Reference this}}"
                   FontSize="24" FontAttributes="Bold" />
                   
            <Label Text="{Binding Title, Source={x:Reference this}}" 
                   Style="{StaticResource StatLabel}" />
                   
        </VerticalStackLayout>
    </Frame>

</ContentView>
