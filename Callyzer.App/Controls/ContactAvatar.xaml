<?xml version="1.0" encoding="utf-8" ?>
<ContentView 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Callyzer.App.Controls.ContactAvatar"
    x:Name="this">

    <Frame BackgroundColor="{Binding AvatarColor, Source={x:Reference this}}"
           WidthRequest="{Binding Size, Source={x:Reference this}}" 
           HeightRequest="{Binding Size, Source={x:Reference this}}" 
           CornerRadius="{Binding CornerRadius, Source={x:Reference this}}"
           Padding="0" HasShadow="False" HorizontalOptions="Center" VerticalOptions="Center">
           
        <Label Text="{Binding Initials, Source={x:Reference this}}" 
               FontSize="{Binding FontSize, Source={x:Reference this}}" 
               FontAttributes="Bold"
               TextColor="White" 
               HorizontalOptions="Center" VerticalOptions="Center" />
    </Frame>

</ContentView>
