<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Callyzer.App.ViewModels"
    x:Class="Callyzer.App.Pages.SyncHistoryPage"
    x:DataType="vm:SyncHistoryViewModel"
    Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">
        
        <!-- Header & Status -->
        <Frame Grid.Row="0" Style="{StaticResource Card}" Margin="16" BackgroundColor="{StaticResource SurfaceVariantColor}">
            <VerticalStackLayout Spacing="16">
                
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Sync Status" Style="{StaticResource Title}" />
                        <Label Text="{Binding LastSyncMessage}" Style="{StaticResource Caption}" />
                        <Label Text="{Binding PendingSyncCount, StringFormat='{0} items pending sync'}" 
                               Style="{StaticResource Body}" TextColor="{StaticResource ErrorColor}" />
                    </VerticalStackLayout>
                    
                    <Button Grid.Column="1" Text="Sync Now" 
                            Style="{StaticResource PrimaryButton}" 
                            Command="{Binding TriggerSyncCommand}" 
                            IsEnabled="{Binding IsSyncing, Converter={StaticResource BoolToColorConverter}, ConverterParameter=invert}" />
                </Grid>

                <ActivityIndicator IsRunning="{Binding IsSyncing}" IsVisible="{Binding IsSyncing}" Color="{StaticResource PrimaryColor}" />
            </VerticalStackLayout>
        </Frame>

        <!-- Call List -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding SyncedLogs}" Margin="16,0,16,16">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:Object">
                    <Frame Style="{StaticResource Card}" Padding="12" Margin="0,4">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <!-- Icon -->
                            <Label Grid.Column="0" Text="{Binding CallType, Converter={StaticResource CallTypeIconConverter}}"
                                   TextColor="{Binding CallType, Converter={StaticResource CallTypeColorConverter}}"
                                   FontSize="24" VerticalOptions="Center" />

                            <!-- Details -->
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding PhoneNumber}" Style="{StaticResource Body}" FontAttributes="Bold" />
                                <Label Text="{Binding CallDate, StringFormat='{0:MMM dd, HH:mm}'}" Style="{StaticResource Caption}" />
                            </VerticalStackLayout>

                            <!-- Sync Status indicator -->
                            <Label Grid.Column="2" 
                                   Text="{Binding SyncStatus}" 
                                   Style="{StaticResource Caption}" 
                                   TextColor="{StaticResource PrimaryColor}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            
            <CollectionView.EmptyView>
                <Label Text="No sync history available." Style="{StaticResource Subtitle}" HorizontalOptions="Center" Margin="0,32,0,0" />
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
