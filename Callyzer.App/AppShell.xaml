<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Callyzer.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Callyzer.App.Pages"
    FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="{StaticResource SurfaceColor}"
    Shell.TabBarTitleColor="{StaticResource PrimaryColor}"
    Shell.TabBarUnselectedColor="{StaticResource TextSecondaryColor}">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- Main Tab Bar -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="home.svg"
            Route="dashboard"
            ContentTemplate="{DataTemplate pages:DashboardPage}" />

        <ShellContent
            Title="Analytics"
            Icon="chart.svg"
            Route="analytics"
            ContentTemplate="{DataTemplate pages:AnalyticsPage}" />

        <ShellContent
            Title="Calls"
            Icon="phone.svg"
            Route="callhistory"
            ContentTemplate="{DataTemplate pages:CallHistoryPage}" />

        <ShellContent
            Title="Settings"
            Icon="settings.svg"
            Route="settings"
            ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </TabBar>

</Shell>
